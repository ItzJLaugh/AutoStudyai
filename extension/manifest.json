{
  "manifest_version": 3,
  "name": "AutoStudyAI",
  "version": "1.1.1",
  "description": "Instantly generate notes, study guides, and flashcards from any lecture, textbook, or course page with AI.",
  "homepage_url": "https://autostudyai.online",
  "minimum_chrome_version": "114",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": ["https://autostudy-ai.fly.dev/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
